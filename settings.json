{
  "permissions": {
    "allow": [
      "Bash(git rev-parse:*)",
      "Bash(git commit:*)",
      "Bash(source:*)",
      "Bash(conda activate:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Search(pattern:*)",
      "Bash(head:*)",
      "Write"
    ],
    "deny": [],
    "ask": [],
    "allowPipes": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-agents-md.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-architecture-md.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty 2>/dev/null"
          },
          {
            "type": "command",
            "command": "curl -s -d 'Claude Code finished' ntfy.sh/alexmathai-cc-notifications"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty 2>/dev/null"
          },
          {
            "type": "command",
            "command": "curl -s -d 'Claude Code Notification' ntfy.sh/alexmathai-cc-notifications"
          }
        ]
      }
    ]
  }
}